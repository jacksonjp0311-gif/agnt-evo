# ============================================
# AGNT Environment Configuration
# ============================================
# Copy this file to .env and edit only the lines you need.
# DO NOT commit .env to version control.
# ============================================

# === DATA DIRECTORY ===========================================
# AGNT defaults to <home>/.agnt/data on every platform.
# That works out-of-the-box for direct-clone (npm start) and Electron builds.
# Uncomment to override the location:
# AGNT_HOME=/home/youruser
#
# AGNT_HOME=~ on Windows expands to your user profile (e.g., C:\Users\You).
# On Linux/Mac use an absolute path. Resolver order:
#   1. /app/data         (Linux Docker — automatic, see below)
#   2. USER_DATA_PATH    (Electron — set automatically by main.js)
#   3. AGNT_HOME         (this file)
#   4. ~/.agnt/data      (default)
# ==============================================================

# === DOCKER ONLY ==============================================
# These are set automatically by docker-compose.yml. Uncomment ONLY if
# running outside docker-compose (bare `docker run`, custom orchestration).
# USER_DATA_PATH=/app/data
# APP_PATH=/app
# ==============================================================

# APPLICATION ENVIRONMENT
# Options: development, production
NODE_ENV=production

# AGNT LITE MODE (Docker only)
# Set to true when running without Chromium/browser support
# This disables Puppeteer/Playwright features gracefully
# Default: false (full mode with browser support)
# AGNT_LITE_MODE=false

# BASE URLS
# Update these to match your domain/deployment
BASE_URL=http://localhost:3333
REMOTE_URL=https://api.agnt.gg
WEBHOOK_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3333

# SERVER PORT
# Default: 3333
PORT=3333

# SECURITY SECRETS
# IMPORTANT: Generate new secure random values for production!
# Generate with: openssl rand -base64 32 (for JWT_SECRET)
#                openssl rand -hex 64 (for SESSION_SECRET)
#                openssl rand -hex 32 (for ENCRYPTION_KEY)
JWT_SECRET=your-random-jwt-secret-here-change-in-production
SESSION_SECRET=your-random-session-secret-here-change-in-production
ENCRYPTION_KEY=your-random-encryption-key-here-change-in-production

# LICENSE KEY (Optional)
# If you have a license key, add it here
# LICENSE_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nYOUR_KEY_HERE\n-----END PUBLIC KEY-----\n"

# AI PROVIDER API KEYS (Optional)
# Setting any of these auto-connects that provider — no UI action needed.
# Resolution order per request:
#   1. env var (this file)
#   2. local SQLite api_keys (UI "Save API Key" writes here, encrypted)
#   3. remote api.agnt.gg fallback (automatic — covers existing remote-stored keys)
# Env wins over DB so a pinned value can't be overridden by a stale row.
# Variable names match each upstream provider's own convention.
#
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...                  # gemini (Google's AI API only; the
#                                       Google Workspace suite — Gmail, Drive,
#                                       YouTube, Sheets, Slides — uses OAuth)
# XAI_API_KEY=...                     # grokai
# GROQ_API_KEY=gsk_...
# DEEPSEEK_API_KEY=...
# OPENROUTER_API_KEY=...
# TOGETHER_API_KEY=...                # togetherai
# CEREBRAS_API_KEY=...
# MOONSHOT_API_KEY=...                # kimi
# MINIMAX_API_KEY=...
# ZAI_API_KEY=...
# CHUTES_API_KEY=...
# MISTRAL_API_KEY=...
# FIREWORKS_API_KEY=...
# DEEPINFRA_API_KEY=...
# PERPLEXITY_API_KEY=...
# SAMBANOVA_API_KEY=...
# NOVITA_API_KEY=...
# NEBIUS_API_KEY=...
# NVIDIA_API_KEY=...                  # nvidia-nim
# SCALEWAY_API_KEY=...
# HYPERBOLIC_API_KEY=...
# LLAMA_API_KEY=...                   # meta-llama
# COHERE_API_KEY=...
# LAMBDA_API_KEY=...
# LEPTON_API_KEY=...
# VLLM_API_KEY=...
# JAN_API_KEY=...

# OPENROUTER APP ATTRIBUTION (Optional)
# Identifies AGNT on OpenRouter app leaderboards (https://openrouter.ai/apps).
# Defaults aggregate every AGNT instance under one app at https://agnt.gg.
# Override only if you intentionally want this instance to appear separately.
# OPENROUTER_APP_REFERER=https://agnt.gg
# OPENROUTER_APP_TITLE=AGNT
# OPENROUTER_APP_CATEGORIES=cli-agent,personal-agent

# OAUTH CONFIGURATION (Optional)
# Google OAuth for authentication
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
# GOOGLE_CALLBACK_URL=http://localhost:3333/auth/google/callback

# PLUGIN CONFIGURATION (Optional)
# Discord Bot Plugin
# DISCORD_BOT_TOKEN=...

# GitHub Plugin
# GITHUB_TOKEN=...

# Slack Plugin
# SLACK_BOT_TOKEN=...
# SLACK_SIGNING_SECRET=...

# Gmail Plugin
# GMAIL_CLIENT_ID=...
# GMAIL_CLIENT_SECRET=...
# GMAIL_REDIRECT_URI=...

# Stripe Plugin
# STRIPE_SECRET_KEY=...
# STRIPE_WEBHOOK_SECRET=...

# Dropbox Plugin
# DROPBOX_APP_KEY=...
# DROPBOX_APP_SECRET=...
# DROPBOX_REDIRECT_URI=...

# Notion Plugin
# NOTION_API_KEY=...

# Firecrawl Plugin
# FIRECRAWL_API_KEY=...

# OpenWeatherMap Plugin
# OPENWEATHERMAP_API_KEY=...

# SMTP EMAIL CONFIGURATION (Optional)
# For sending emails
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password

# LOGGING (Optional)
# LOG_LEVEL=info
# LOG_FILE=/app/logs/agnt.log

# DATABASE (Optional)
# SQLite is used by default, stored under the resolved AGNT data dir (see top of file).
# DATABASE_PATH=/app/data/agnt.db

# SQLITE_WAL_MODE (Optional, default: false)
# Enable Write-Ahead Logging (WAL) mode for better multi-client concurrency
# WARNING: Only enable if you need multiple devices/clients accessing the same backend
# Single-user scenarios should leave this disabled for better performance
# When enabled: Multiple readers + queued writes (5s timeout)
# When disabled: Standard journaling (better for single-user)
# SQLITE_WAL_MODE=false

# ADVANCED CONFIGURATION (Optional)
# CORS_ORIGINS=http://localhost:3333,https://yourdomain.com
# MAX_FILE_SIZE=10485760
# SESSION_MAX_AGE=86400000
