{
  "name": "chemiframe",
  "version": "4.0.0",
  "description": "High-level chemical programming compiler — self-contained, marketplace-ready AGNT plugin. 15 tools: natural language parsing, SMILES input, reaction validation, cost optimization, campaign planning, analytical recommendations, plus core compile/validate/simulate/retrosynthesis/execute/demo/blueprints/check-env/quickstart. 14 reaction blueprints across small molecule, biopolymer, and chemo-bio domains.",
  "author": "James Paul Jackson",
  "icon": "flask",
  "homepage": "https://github.com/jacksonjp0311-gif/CHEMIFRAME-AGENT-PLUGIN",
  "displayName": "CHEMIFRAME",
  "category": "science",
  "tags": ["chemistry", "chemical-programming", "synthesis", "xdl", "blueprints", "contract-verification", "oligonucleotide", "chemo-bio", "hybrid", "small-molecule", "sequence-assembly", "retrosynthesis", "protocol-design", "wet-lab", "automation", "science", "rdkit", "grignard", "diels-alder", "click-chemistry", "friedel-crafts", "reductive-amination", "snar", "enzymatic", "biocatalysis", "natural-language", "smiles", "cost-optimization", "campaign-planning", "analytical-methods"],
  "tools": [
    {
      "type": "chemiframe-demo",
      "entryPoint": "./chemiframe-demo.js",
      "schema": {
        "title": "CHEMIFRAME Demo",
        "category": "action",
        "type": "chemiframe-demo",
        "icon": "play",
        "description": "Run a pre-built demo pipeline (Suzuki coupling, oligonucleotide synthesis, or chemo-bio hybrid).",
        "parameters": {
          "demo_type": { "type": "string", "inputType": "select", "options": ["small_molecule", "sequence", "hybrid"], "required": false, "description": "Which demo to run. Default: small_molecule." },
          "simulate": { "type": "boolean", "required": false, "description": "Run simulation after compilation. Default: true." }
        },
        "outputs": { "success": { "type": "boolean" }, "demo_type": { "type": "string" }, "route": { "type": "object" }, "contracts": { "type": "object" } }
      }
    },
    {
      "type": "chemiframe-blueprints",
      "entryPoint": "./chemiframe-blueprints.js",
      "schema": {
        "title": "CHEMIFRAME Blueprints",
        "category": "action",
        "type": "chemiframe-blueprints",
        "icon": "list",
        "description": "List all 14 reaction blueprints with admissibility criteria, yields, catalysts, temperatures.",
        "parameters": {
          "domain_filter": { "type": "string", "inputType": "select", "options": ["all", "small_molecule", "sequence_defined_biopolymer", "oligonucleotide_synthesis", "hybrid_chemo_bio"], "required": false }
        },
        "outputs": { "success": { "type": "boolean" }, "blueprints": { "type": "array" }, "count": { "type": "number" } }
      }
    },
    {
      "type": "chemiframe-compile",
      "entryPoint": "./chemiframe-compile.js",
      "schema": {
        "title": "CHEMIFRAME Compile",
        "category": "action",
        "type": "chemiframe-compile",
        "icon": "flask",
        "description": "Full pipeline: intent → route → contracts → XDL.",
        "parameters": {
          "intent": { "type": "string", "inputType": "codearea", "required": true, "description": "Chemical intent as YAML or JSON." },
          "domain": { "type": "string", "inputType": "select", "options": ["small_molecule", "sequence_defined_biopolymer", "oligonucleotide_synthesis", "hybrid_chemo_bio"], "required": false }
        },
        "outputs": { "success": { "type": "boolean" }, "route": { "type": "object" }, "contracts": { "type": "object" }, "xdl": { "type": "string" }, "route_id": { "type": "string" }, "blueprint": { "type": "string" } }
      }
    },
    {
      "type": "chemiframe-validate",
      "entryPoint": "./chemiframe-validate.js",
      "schema": {
        "title": "CHEMIFRAME Validate",
        "category": "action",
        "type": "chemiframe-validate",
        "icon": "check",
        "description": "Contract verification only — detectability, assembly bounds, decision points, admissibility.",
        "parameters": { "intent": { "type": "string", "inputType": "codearea", "required": true } },
        "outputs": { "success": { "type": "boolean" }, "contracts": { "type": "object" }, "detectability_ok": { "type": "boolean" }, "assembly_bound_ok": { "type": "boolean" }, "dec_points_defined": { "type": "boolean" }, "route_admissible": { "type": "boolean" } }
      }
    },
    {
      "type": "chemiframe-simulate",
      "entryPoint": "./chemiframe-simulate.js",
      "schema": {
        "title": "CHEMIFRAME Simulate",
        "category": "action",
        "type": "chemiframe-simulate",
        "icon": "beaker",
        "description": "Three-tier simulation (RDKit → IBM RXN → rule-based). Returns DEC events, yield predictions.",
        "parameters": { "intent": { "type": "string", "inputType": "codearea", "required": true } },
        "outputs": { "success": { "type": "boolean" }, "run_id": { "type": "string" }, "dec_events": { "type": "array" }, "simulation": { "type": "object" }, "route": { "type": "object" } }
      }
    },
    {
      "type": "chemiframe-retrosynthesis",
      "entryPoint": "./chemiframe-retrosynthesis.js",
      "schema": {
        "title": "CHEMIFRAME Retrosynthesis",
        "category": "action",
        "type": "chemiframe-retrosynthesis",
        "icon": "branch",
        "description": "Predict retrosynthetic pathways from target name or SMILES.",
        "parameters": {
          "target": { "type": "string", "required": false, "description": "Target molecule name." },
          "target_smiles": { "type": "string", "required": false, "description": "Target as SMILES string." },
          "max_steps": { "type": "number", "required": false, "description": "Max retrosynthetic steps. Default: 5." }
        },
        "outputs": { "success": { "type": "boolean" }, "products": { "type": "array" }, "confidence": { "type": "number" }, "engine": { "type": "string" } }
      }
    },
    {
      "type": "chemiframe-execute",
      "entryPoint": "./chemiframe-execute.js",
      "schema": {
        "title": "CHEMIFRAME Execute",
        "category": "action",
        "type": "chemiframe-execute",
        "icon": "run",
        "description": "Full end-to-end: compile → verify → execute → trace.",
        "parameters": {
          "intent": { "type": "string", "inputType": "codearea", "required": true },
          "dry_run": { "type": "boolean", "required": false }
        },
        "outputs": { "success": { "type": "boolean" }, "run_id": { "type": "string" }, "status": { "type": "string" }, "trace_path": { "type": "string" }, "route": { "type": "object" } }
      }
    },
    {
      "type": "chemiframe-check-env",
      "entryPoint": "./chemiframe-check-env.js",
      "schema": {
        "title": "CHEMIFRAME Check Environment",
        "category": "action",
        "type": "chemiframe-check-env",
        "icon": "gear",
        "description": "Verify Python, RDKit, IBM RXN API key status.",
        "parameters": {},
        "outputs": { "success": { "type": "boolean" }, "python": { "type": "string" }, "rdkit": { "type": "boolean" }, "ibm_rxn": { "type": "boolean" }, "simulation_tier": { "type": "string" }, "warnings": { "type": "array" } }
      }
    },
    {
      "type": "chemiframe-quickstart",
      "entryPoint": "./chemiframe-quickstart.js",
      "schema": {
        "title": "CHEMIFRAME Quickstart",
        "category": "action",
        "type": "chemiframe-quickstart",
        "icon": "book",
        "description": "Curated example intents for every domain.",
        "parameters": { "format": { "type": "string", "inputType": "select", "options": ["markdown", "json"], "required": false } },
        "outputs": { "success": { "type": "boolean" }, "guide": { "type": "string" }, "examples": { "type": "object" }, "count": { "type": "number" } }
      }
    },
    {
      "type": "chemiframe-nl-parse",
      "entryPoint": "./chemiframe-nl-parse.js",
      "schema": {
        "title": "CHEMIFRAME NL Parse",
        "category": "action",
        "type": "chemiframe-nl-parse",
        "icon": "message",
        "description": "Natural language intent parser. Translates plain English chemical descriptions into structured CHEMIFRAME intents. E.g., 'Suzuki coupling with green solvents, max 6 steps'.",
        "parameters": {
          "nl_text": { "type": "string", "inputType": "codearea", "required": true, "description": "Natural language description of the desired synthesis." },
          "auto_compile": { "type": "boolean", "required": false, "description": "Automatically compile the extracted intent. Default: false." }
        },
        "outputs": { "success": { "type": "boolean" }, "intent": { "type": "object" }, "intent_yaml": { "type": "string" }, "compiled": { "type": "boolean" }, "confidence": { "type": "string" }, "route": { "type": "object" }, "contracts": { "type": "object" }, "xdl": { "type": "string" } }
      }
    },
    {
      "type": "chemiframe-smiles-input",
      "entryPoint": "./chemiframe-smiles-input.js",
      "schema": {
        "title": "CHEMIFRAME SMILES Input",
        "category": "action",
        "type": "chemiframe-smiles-input",
        "icon": "atom",
        "description": "SMILES-native intent input. Paste a target molecule SMILES and get functional group analysis, retrosynthetic suggestions, and auto-generated intent.",
        "parameters": {
          "target_smiles": { "type": "string", "required": true, "description": "Target molecule as SMILES string." },
          "auto_compile": { "type": "boolean", "required": false, "description": "Auto-compile the generated intent. Default: true." }
        },
        "outputs": { "success": { "type": "boolean" }, "input_smiles": { "type": "string" }, "analysis": { "type": "object" }, "intent": { "type": "object" }, "compiled": { "type": "boolean" }, "route": { "type": "object" }, "contracts": { "type": "object" }, "xdl": { "type": "string" } }
      }
    },
    {
      "type": "chemiframe-validate-reaction",
      "entryPoint": "./chemiframe-validate-reaction.js",
      "schema": {
        "title": "CHEMIFRAME Validate Reaction",
        "category": "action",
        "type": "chemiframe-validate-reaction",
        "icon": "shield",
        "description": "Validate a reaction against known chemistry. Checks literature precedent, template match, and adjusts confidence.",
        "parameters": { "intent": { "type": "string", "inputType": "codearea", "required": true } },
        "outputs": { "success": { "type": "boolean" }, "route": { "type": "object" }, "validation": { "type": "object" }, "literature_precedent": { "type": "string" }, "known_reaction": { "type": "boolean" }, "similar_reactions": { "type": "number" } }
      }
    },
    {
      "type": "chemiframe-cost-optimize",
      "entryPoint": "./chemiframe-cost-optimize.js",
      "schema": {
        "title": "CHEMIFRAME Cost Optimize",
        "category": "action",
        "type": "chemiframe-cost-optimize",
        "icon": "dollar",
        "description": "Cost-aware route scoring. Estimates reagent, solvent, purification, and equipment costs. Applies green chemistry discounts.",
        "parameters": {
          "intent": { "type": "string", "inputType": "codearea", "required": true },
          "optimize": { "type": "boolean", "required": false }
        },
        "outputs": { "success": { "type": "boolean" }, "route": { "type": "object" }, "cost_breakdown": { "type": "object" }, "step_count": { "type": "number" }, "cost_per_step": { "type": "number" } }
      }
    },
    {
      "type": "chemiframe-campaign",
      "entryPoint": "./chemiframe-campaign.js",
      "schema": {
        "title": "CHEMIFRAME Campaign",
        "category": "action",
        "type": "chemiframe-campaign",
        "icon": "project",
        "description": "Multi-step campaign planner. Generates parallel step scheduling, equipment requirements, intermediate identification, and time estimates.",
        "parameters": {
          "intent": { "type": "string", "inputType": "codearea", "required": true },
          "max_depth": { "type": "number", "required": false, "description": "Campaign planning depth. Default: 3." }
        },
        "outputs": { "success": { "type": "boolean" }, "campaign": { "type": "object" }, "route": { "type": "object" }, "step_sequence": { "type": "array" } }
      }
    },
    {
      "type": "chemiframe-analytical",
      "entryPoint": "./chemiframe-analytical.js",
      "schema": {
        "title": "CHEMIFRAME Analytical",
        "category": "action",
        "type": "chemiframe-analytical",
        "icon": "chart",
        "description": "Analytical method recommender. Suggests monitoring methods (HPLC, TLC, NMR, MS) for each step. Identifies critical control points for AGNT automation.",
        "parameters": { "intent": { "type": "string", "inputType": "codearea", "required": true } },
        "outputs": { "success": { "type": "boolean" }, "recommendations": { "type": "array" }, "summary": { "type": "object" }, "route": { "type": "object" } }
      }
    }
  ]
}
