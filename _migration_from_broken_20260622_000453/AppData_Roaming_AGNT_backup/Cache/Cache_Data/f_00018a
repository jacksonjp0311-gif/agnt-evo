rams, credentials, config) {\n  const oauth2Client = new google.auth.OAuth2(\n    credentials.clientId,\n    credentials.clientSecret,\n    credentials.redirectUri\n  );\n  \n  try {\n    oauth2Client.setCredentials({ refresh_token: params.refreshToken });\n    const { credentials: newCredentials } = await oauth2Client.refreshAccessToken();\n    return {\n      access_token: newCredentials.access_token,\n      refresh_token: newCredentials.refresh_token || params.refreshToken,\n      expires_at: newCredentials.expiry_date,\n    };\n  } catch (error) {\n    console.error('Error refreshing tokens:', error);\n    throw new Error('Failed to refresh tokens');\n  }\n}\n","created_at":"2026-05-20 04:06:54","updated_at":"2026-05-20 04:06:54","is_built_in":0,"auth_url":null,"token_url":null,"refresh_url":null,"auth_params":null,"supports_refresh":1,"token_format":"form","token_auth_header":"none","token_method":"POST","client_id":null,"user_id":null,"client_secret":null,"token_params":null,"token_headers":null,"refresh_params":null,"refresh_headers":null,"created_by":null,"is_global":"1"},{"id":"ebay","name":"eBay","icon":"ebay","categories":"[\"commerce\",\"marketplace\",\"selling\"]","connection_type":"oauth","instructions":"Connect your eBay seller account to search listings, manage inventory, offers, account policies, orders, fulfillment, marketing, stores, messaging, feedback, shipping, notifications, and related seller APIs.","custom_prompt":"","redirect_uri":"Nathan_Wilbanks-NathanWi-AGNT-P-dnihcr","scope":"https://api.ebay.com/oauth/api_scope https://api.ebay.com/oauth/api_scope/sell.marketing.readonly https://api.ebay.com/oauth/api_scope/sell.marketing https://api.ebay.com/oauth/api_scope/sell.inventory.readonly https://api.ebay.com/oauth/api_scope/sell.inventory https://api.ebay.com/oauth/api_scope/sell.account.readonly https://api.ebay.com/oauth/api_scope/sell.account https://api.ebay.com/oauth/api_scope/sell.fulfillment.readonly https://api.ebay.com/oauth/api_sco