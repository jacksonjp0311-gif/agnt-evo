+          const blob = new Blob([JSON.stringify(artifact, null, 2)], { type: 'application/json' });
+          const url = URL.createObjectURL(blob);
+          const a = document.createElement('a');
+          a.href = url;
+          a.download = `conversation-artifact-${Date.now()}.json`;
