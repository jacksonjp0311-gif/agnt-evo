{
  "name": "open-url-toolkit",
  "displayName": "Open URL Toolkit",
  "version": "0.4.0",
  "description": "Open URL Toolkit: open URLs inline (embed), open URLs in your external browser (native), authorize button widget, plus advanced URL building and rate limiting.",
  "author": "James Paul Jackson",
  "icon": "terminal",
  "homepage": "https://github.com/jacksonjp0311-gif/open-url-toolkit",
  "tools": [
    {
      "type": "open-url",
      "entryPoint": "./open-url.js",
      "schema": {
        "title": "Open URL",
        "category": "utility",
        "type": "open-url",
        "icon": "terminal",
        "description": "Returns a safe clickable URL plus optional iframe HTML for inline UI preview.",
        "parameters": {
          "url": {
            "type": "string",
            "inputType": "text",
            "required": true,
            "description": "URL to open (http/https/localhost recommended)."
          },
          "embed": {
            "type": "string",
            "inputType": "select",
            "required": true,
            "options": [
              "false",
              "true"
            ],
            "default": "true",
            "description": "If true, also return iframe HTML for inline preview."
          },
          "height": {
            "type": "number",
            "inputType": "number",
            "required": false,
            "default": 720,
            "minimum": 200,
            "maximum": 2000,
            "description": "Iframe height in pixels (when embed=true)."
          },
          "width": {
            "type": "string",
            "inputType": "text",
            "required": false,
            "default": "100%",
            "description": "Iframe width (CSS value)."
          }
        },
        "outputs": {
          "success": {
            "type": "boolean",
            "description": "Whether the tool succeeded"
          },
          "url": {
            "type": "string",
            "description": "Normalized URL"
          },
          "markdown": {
            "type": "string",
            "description": "Markdown snippet with a clickable link"
          },
          "iframeHtml": {
            "type": "string",
            "description": "HTML iframe snippet (if embed=true)"
          },
          "error": {
            "type": "string",
            "description": "Error message if failed"
          }
        }
      }
    },
    {
      "type": "authorize-button",
      "entryPoint": "./authorize-button.js",
      "schema": {
        "title": "Authorize Button",
        "category": "utility",
        "type": "authorize-button",
        "icon": "terminal",
        "description": "Returns an HTML widget containing an Authorize & Continue button that POSTs JSON to a webhook URL.",
        "parameters": {
          "webhookUrl": {
            "type": "string",
            "inputType": "text",
            "required": true,
            "description": "Webhook URL to POST authorization payload to."
          },
          "payloadJson": {
            "type": "string",
            "inputType": "codearea",
            "required": false,
            "description": "JSON payload to send on click (object or JSON string)."
          },
          "buttonText": {
            "type": "string",
            "inputType": "text",
            "required": false,
            "default": "Authorize & Continue",
            "description": "Button label."
          },
          "description": {
            "type": "string",
            "inputType": "text",
            "required": false,
            "default": "Authorization required to proceed.",
            "description": "Short description shown above the button."
          },
          "openAfter": {
            "type": "string",
            "inputType": "select",
            "required": true,
            "options": [
              "false",
              "true"
            ],
            "default": "false",
            "description": "If true, open a URL after successful authorization."
          },
          "openUrl": {
            "type": "string",
            "inputType": "text",
            "required": false,
            "description": "URL to open if openAfter=true."
          }
        },
        "outputs": {
          "success": {
            "type": "boolean",
            "description": "Whether the tool succeeded"
          },
          "webhookUrl": {
            "type": "string",
            "description": "Webhook URL used"
          },
          "markdown": {
            "type": "string",
            "description": "Plain markdown fallback"
          },
          "html": {
            "type": "string",
            "description": "HTML widget containing the button + status"
          },
          "error": {
            "type": "string",
            "description": "Error message if failed"
          }
        }
      }
    },
    {
      "type": "open-url-native",
      "entryPoint": "./open-url-native.js",
      "schema": {
        "title": "Open URL (Native Browser)",
        "category": "utility",
        "type": "open-url-native",
        "icon": "terminal",
        "description": "Opens a URL in your external system browser (outside AGNT). Supports browser targeting and built-in rate limiting.",
        "parameters": {
          "url": {
            "type": "string",
            "inputType": "text",
            "required": true,
            "description": "http(s) URL to open in the external browser."
          },
          "confirm": {
            "type": "string",
            "inputType": "select",
            "required": true,
            "options": [
              "false",
              "true"
            ],
            "default": "false",
            "description": "Safety gate. Must be true to actually open the browser."
          },
          "allowFile": {
            "type": "string",
            "inputType": "select",
            "required": true,
            "options": [
              "false",
              "true"
            ],
            "default": "false",
            "description": "If true, allow file:/// URLs too."
          },
          "browser": {
            "type": "string",
            "inputType": "select",
            "required": true,
            "options": [
              "default",
              "chrome",
              "edge",
              "firefox"
            ],
            "default": "default",
            "description": "Which browser to target (best-effort). default uses OS default browser."
          },
          "profileDirectory": {
            "type": "string",
            "inputType": "text",
            "required": false,
            "description": "Browser profile directory name (best-effort). Chrome/Edge: e.g. \"Default\" or \"Profile 1\". Firefox: profile name."
          },
          "newWindow": {
            "type": "string",
            "inputType": "select",
            "required": true,
            "options": [
              "false",
              "true"
            ],
            "default": "false",
            "description": "Best-effort open in a new window (browser-dependent)."
          },
          "maxLaunches": {
            "type": "number",
            "inputType": "number",
            "required": false,
            "default": 3,
            "minimum": 1,
            "maximum": 50,
            "description": "Rate limit: max browser opens per time window."
          },
          "windowSeconds": {
            "type": "number",
            "inputType": "number",
            "required": false,
            "default": 10,
            "minimum": 1,
            "maximum": 600,
            "description": "Rate limit window in seconds."
          },
          "disableRateLimit": {
            "type": "string",
            "inputType": "select",
            "required": true,
            "options": [
              "false",
              "true"
            ],
            "default": "false",
            "description": "If true, disables rate limiting (not recommended for public workflows)."
          }
        },
        "outputs": {
          "success": {
            "type": "boolean",
            "description": "Whether the tool succeeded"
          },
          "launched": {
            "type": "boolean",
            "description": "Whether a browser open was attempted"
          },
          "url": {
            "type": "string",
            "description": "URL that was requested/opened"
          },
          "platform": {
            "type": "string",
            "description": "process.platform used to choose open command"
          },
          "command": {
            "type": "string",
            "description": "Command used to open the browser"
          },
          "args": {
            "type": "array",
            "description": "Arguments used to open the browser"
          },
          "pid": {
            "type": "number",
            "description": "Spawned process pid (if available)"
          },
          "error": {
            "type": "string",
            "description": "Error message if failed"
          },
          "rateLimited": {
            "type": "boolean",
            "description": "True if the open was blocked by rate limiting."
          },
          "cooldownRemainingMs": {
            "type": "number",
            "description": "If rate-limited, ms remaining until next open is allowed."
          },
          "countInWindow": {
            "type": "number",
            "description": "Count of opens in the current window."
          }
        }
      }
    },
    {
      "type": "open-url-native-plus",
      "entryPoint": "./open-url-native-plus.js",
      "schema": {
        "title": "Open URL (Native) + Query Builder",
        "category": "utility",
        "type": "open-url-native-plus",
        "icon": "terminal",
        "description": "Build a URL from baseUrl + query object (encoded) and open it in the external system browser.",
        "parameters": {
          "baseUrl": {
            "type": "string",
            "inputType": "text",
            "required": true,
            "description": "Base URL (http/https) to open."
          },
          "queryJson": {
            "type": "string",
            "inputType": "codearea",
            "required": false,
            "description": "JSON object to merge into URL query string."
          },
          "confirm": {
            "type": "string",
            "inputType": "select",
            "required": true,
            "options": [
              "false",
              "true"
            ],
            "default": "false",
            "description": "Safety gate. Must be true to actually open the browser."
          }
        },
        "outputs": {
          "success": {
            "type": "boolean",
            "description": "Whether the tool succeeded"
          },
          "launched": {
            "type": "boolean",
            "description": "Whether a browser open was attempted"
          },
          "url": {
            "type": "string",
            "description": "Final URL that was opened"
          },
          "platform": {
            "type": "string",
            "description": "process.platform used to choose open command"
          },
          "command": {
            "type": "string",
            "description": "Command used to open the browser"
          },
          "args": {
            "type": "array",
            "description": "Arguments used to open the browser"
          },
          "pid": {
            "type": "number",
            "description": "Spawned process pid (if available)"
          },
          "error": {
            "type": "string",
            "description": "Error message if failed"
          }
        }
      }
    }
  ]
}